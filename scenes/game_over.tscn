[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/game_over.gd" id="1_script"]

[node name="GameOver" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
color = Color(0.05, 0.02, 0.02, 1)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="MainVBox" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="Center/MainVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "Game Over"
horizontal_alignment = 1

[node name="Prompt" type="Label" parent="Center/MainVBox"]
custom_minimum_size = Vector2(520, 0)
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Your path ends here. Load from your last save to try again."
horizontal_alignment = 1
autowrap_mode = 3

[node name="LoadLastSaveButton" type="Button" parent="Center/MainVBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 4
text = "Load last save"

[node name="ErrorLabel" type="Label" parent="Center/MainVBox"]
unique_name_in_owner = true
visible = false
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.45, 0.45, 1)
theme_override_font_sizes/font_size = 16
horizontal_alignment = 1
autowrap_mode = 3

[connection signal="pressed" from="Center/MainVBox/LoadLastSaveButton" to="." method="_on_load_last_save_pressed"]
