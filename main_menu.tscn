[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://main_menu.gd" id="1_main_menu"]
[ext_resource type="PackedScene" path="res://settings_menu.tscn" id="2_settings_menu"]

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_main_menu")

[node name="MainPanel" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -140.0
offset_top = -100.0
offset_right = 140.0
offset_bottom = 100.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="MainPanel"]
layout_mode = 2
text = "Telvar: Secundus"
horizontal_alignment = 1

[node name="PlayButton" type="Button" parent="MainPanel"]
layout_mode = 2
text = "Play"

[node name="SettingsButton" type="Button" parent="MainPanel"]
layout_mode = 2
text = "Settings"

[node name="QuitButton" type="Button" parent="MainPanel"]
layout_mode = 2
text = "Quit"

[node name="SettingsHost" type="Control" parent="."]
visible = false
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="SettingsMenu" parent="SettingsHost" instance=ExtResource("2_settings_menu")]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[connection signal="pressed" from="MainPanel/PlayButton" to="." method="_on_play_pressed"]
[connection signal="pressed" from="MainPanel/SettingsButton" to="." method="_on_settings_pressed"]
[connection signal="pressed" from="MainPanel/QuitButton" to="." method="_on_quit_pressed"]
